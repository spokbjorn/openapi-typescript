{
  "name": "openapi-typescript",
  "version": "0.0.2-pre.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --fail-if-no-match --filter @spokbjorn/* build",
    "test": "pnpm --fail-if-no-match --filter @spokbjorn/* test",
    "typecheck": "pnpm --fail-if-no-match --filter @spokbjorn/* typecheck",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": "eslint --fix"
  },
  "devDependencies": {
    "@spokbjorn/eslint-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:"
  }
}
